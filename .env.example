# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/laminar_database
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# FastAPI
SECRET_KEY=changeme
DEBUG=true
FASTAPI_PORT=8000

# Nginx (host port; use different values per env to avoid conflicts, e.g. dev 80, uat 81, prod 82)
NGINX_PORT=80

# Migrations: set RUN_MIGRATIONS=1 only for the backend service (docker-compose sets this; do not set for celery)
# RUN_MIGRATIONS=1
