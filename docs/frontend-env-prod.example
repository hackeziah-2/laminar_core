# Copy to laminaraviationapp as .env.prod
# Prod frontend – HTTPS domains (recommended)
NODE_ENV=production
VITE_APP_URL=https://fleet.laminaraviationapps.com
VITE_API_URL=/api/v1/
# WebSocket must use api-fleet: fleet.laminaraviationapps.com proxies REST /api/v1/
# but does not upgrade WebSocket on /api/v1/notifications/ws (returns 404).
VITE_WS_URL=wss://api-fleet.laminaraviationapps.com/api/v1

# Legacy IP-based deployment (if not using HTTPS domains):
# VITE_APP_URL=http://120.89.33.51:3002
# VITE_API_URL=http://120.89.33.51:8200/api/v1/
# VITE_WS_URL=ws://120.89.33.51:8082/api/v1
